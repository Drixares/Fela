{
  "name": "fela",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "checks": "turbo run check-types",
    "test": "turbo run test",
    "prepare": "husky",
    "db:push": "pnpm --filter @repo/db db:push",
    "db:generate": "pnpm --filter @repo/db db:generate",
    "db:studio": "pnpm --filter @repo/db db:studio"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.7.4",
    "turbo": "^2.10.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3"
    ],
    "//overrides": "Force one @types/react across the workspace. The renderer consumes @repo/ui as source, so its typecheck compiles the UI .tsx files; two @types/react copies make tsc report 'two different types with this name exist'.",
    "overrides": {
      "@types/react": "19.2.17",
      "@types/react-dom": "19.2.3"
    }
  }
}
